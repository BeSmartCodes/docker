FROM docker.io/calcom/cal.com:latest

# --- Smart Live Cam branding (logos) ---
RUN printf '%s' '<svg viewBox="0 0 100 100" xmlns="http://www.w3.org/2000/svg"><path d="M 73.4 20.1 A 38.0 38.0 0 1 0 73.4 79.9" fill="none" stroke="#3D8BFF" stroke-width="11.0" stroke-linecap="round"/><circle cx="50" cy="50" r="20.0" fill="#3D8BFF"/><circle cx="50" cy="50" r="11.0" fill="#0B132B"/><circle cx="56.5" cy="43.5" r="4.0" fill="#FFFFFF"/><circle cx="73.4" cy="20.1" r="8.0" fill="#FF2E9A"/><circle cx="73.4" cy="79.9" r="5.5" fill="#3D8BFF"/></svg>' > /calcom/apps/web/public/cal-com-icon.svg
RUN printf '%s' '<svg viewBox="0 0 100 100" xmlns="http://www.w3.org/2000/svg"><path d="M 73.4 20.1 A 38.0 38.0 0 1 0 73.4 79.9" fill="none" stroke="#FFFFFF" stroke-width="11.0" stroke-linecap="round"/><circle cx="50" cy="50" r="20.0" fill="#FFFFFF"/><circle cx="50" cy="50" r="11.0" fill="#0B132B"/><circle cx="56.5" cy="43.5" r="4.0" fill="#FFFFFF"/><circle cx="73.4" cy="20.1" r="8.0" fill="#FF2E9A"/><circle cx="73.4" cy="79.9" r="5.5" fill="#FFFFFF"/></svg>' > /calcom/apps/web/public/cal-com-icon-white.svg
RUN printf '%s' '<svg viewBox="0 0 430 100" xmlns="http://www.w3.org/2000/svg"><path d="M 60.2 26.6 A 29.6 29.6 0 1 0 60.2 73.4" fill="none" stroke="#3D8BFF" stroke-width="8.6" stroke-linecap="round"/><circle cx="42" cy="50" r="15.6" fill="#3D8BFF"/><circle cx="42" cy="50" r="8.6" fill="#0B132B"/><circle cx="47.1" cy="44.9" r="3.1" fill="#FFFFFF"/><circle cx="60.2" cy="26.6" r="6.2" fill="#FF2E9A"/><circle cx="60.2" cy="73.4" r="4.3" fill="#3D8BFF"/><text x="92" y="64" font-family="Arial, Helvetica, sans-serif" font-weight="700" font-size="38"><tspan fill="#0B132B">Smart </tspan><tspan fill="#3D8BFF">Live</tspan><tspan fill="#0B132B"> Cam</tspan></text></svg>' > /calcom/apps/web/public/cal-logo-word.svg
RUN printf '%s' '<svg viewBox="0 0 430 100" xmlns="http://www.w3.org/2000/svg"><path d="M 60.2 26.6 A 29.6 29.6 0 1 0 60.2 73.4" fill="none" stroke="#FFFFFF" stroke-width="8.6" stroke-linecap="round"/><circle cx="42" cy="50" r="15.6" fill="#FFFFFF"/><circle cx="42" cy="50" r="8.6" fill="#0B132B"/><circle cx="47.1" cy="44.9" r="3.1" fill="#FFFFFF"/><circle cx="60.2" cy="26.6" r="6.2" fill="#FF2E9A"/><circle cx="60.2" cy="73.4" r="4.3" fill="#FFFFFF"/><text x="92" y="64" font-family="Arial, Helvetica, sans-serif" font-weight="700" font-size="38"><tspan fill="#FFFFFF">Smart </tspan><tspan fill="#3D8BFF">Live</tspan><tspan fill="#FFFFFF"> Cam</tspan></text></svg>' > /calcom/apps/web/public/cal-logo-word-dark.svg
RUN printf '%s' '<svg viewBox="0 0 430 100" xmlns="http://www.w3.org/2000/svg"><path d="M 60.2 26.6 A 29.6 29.6 0 1 0 60.2 73.4" fill="none" stroke="#3D8BFF" stroke-width="8.6" stroke-linecap="round"/><circle cx="42" cy="50" r="15.6" fill="#3D8BFF"/><circle cx="42" cy="50" r="8.6" fill="#0B132B"/><circle cx="47.1" cy="44.9" r="3.1" fill="#FFFFFF"/><circle cx="60.2" cy="26.6" r="6.2" fill="#FF2E9A"/><circle cx="60.2" cy="73.4" r="4.3" fill="#3D8BFF"/><text x="92" y="64" font-family="Arial, Helvetica, sans-serif" font-weight="700" font-size="38"><tspan fill="#0B132B">Smart </tspan><tspan fill="#0B132B">Live</tspan><tspan fill="#0B132B"> Cam</tspan></text></svg>' > /calcom/apps/web/public/cal-logo-word-black.svg

# --- Favicon ---
RUN echo '' | base64 -d > /calcom/apps/web/public/favicon.ico
RUN echo '' | base64 -d > /calcom/apps/web/public/favicon-32x32.png
RUN echo '' | base64 -d > /calcom/apps/web/public/favicon-16x16.png
RUN echo '' | base64 -d > /calcom/apps/web/public/apple-touch-icon.png

# --- Footer text ---
RUN find /calcom/apps/web/.next -type f -name "*.js" -exec sed -i 's/Cal\.com, Inc/Smart Live Cam/g' {} + || true
